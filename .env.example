# ── Secrets — generate fresh for each deploy ───────────────────────────────
# Postgres DB password. Use 32+ random chars: `openssl rand -hex 32`
POSTGRES_PASSWORD=change-me-to-something-long
# Grafana admin password for the initial `admin` user.
GRAFANA_ADMIN_PASSWORD=change-me-too

# ── Domains — must have A records pointing to this server's IP ─────────────
TELEMETRY_DOMAIN=telemetry.useaxor.net
GRAFANA_DOMAIN=grafana.useaxor.net

# ── ACME / Let's Encrypt ───────────────────────────────────────────────────
# Email used for cert expiry notifications and ACME account registration.
# If unset, Caddy still gets certs but LE has no way to warn you about issues.
ACME_EMAIL=d.buchilin@eleganza.ai
